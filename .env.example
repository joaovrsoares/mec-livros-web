# ======================================================
# Configurações de Ambiente - MEC Livros Web
# Copie este arquivo para .env.local em ambiente de dev
# ======================================================

# Token de Autenticação Bearer (Obrigatório para downloads de EPUB)
MEC_LIVROS_BEARER_TOKEN=cole_seu_token_aqui

# Chaves de Descriptografia AES-256 (32 bytes para a KEY, 16 bytes para o IV)
MEC_LIVROS_AES_KEY=R1FTmXDFrfIlQvpLg8PkDvuuW3cmss56
MEC_LIVROS_AES_IV=lSrKOxW5xDPU7BMr

# Rate Limiting de Download por Cliente (IP)
MEC_DOWNLOAD_SHORT_WINDOW_SECONDS=45
MEC_DOWNLOAD_SHORT_WINDOW_MAX=1
MEC_DOWNLOAD_DAILY_MAX=25

# (Opcional) Conexão Redis para Rate Limiting distribuído em réplicas / serverless
# UPSTASH_REDIS_REST_URL=https://...upstash.io
# UPSTASH_REDIS_REST_TOKEN=...
